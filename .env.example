# SeloraX Canvas — Environment Variables Template
# Copy to .env and fill in values

# ── MVP Tenant ─────────────────────────────────────────────────
MVP_MODE=true
TENANT_ID=
TENANT_NAME=
TENANT_DOMAIN=
TENANT_PLAN=pro

# ── SpacetimeDB Maincloud ──────────────────────────────────────
SPACETIMEDB_URL=wss://maincloud.spacetimedb.com
SPACETIMEDB_DB_NAME=
NEXT_PUBLIC_SPACETIMEDB_URL=wss://maincloud.spacetimedb.com
NEXT_PUBLIC_SPACETIMEDB_DB=

# ── MySQL ──────────────────────────────────────────────────────
DATABASE_URL=

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=

# ── AI ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Cloudflare R2 / Component CDN ─────────────────────────────
S3_PUBLIC_URL=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── Service URLs ───────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
BACKEND_URL=http://canvas-backend:3001
DASHBOARD_URL=http://localhost:3002

# ── Cloudflare Cache Purge (optional) ─────────────────────────
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
